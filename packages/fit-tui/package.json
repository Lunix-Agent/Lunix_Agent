{
  "name": "@_davideast/fit",
  "version": "0.1.0",
  "description": "FIT file database and query library for Bun and Node.js",
  "license": "MIT",
  "author": "David East",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davideast/fitui.git",
    "directory": "packages/fit-tui"
  },
  "keywords": [
    "fit",
    "garmin",
    "duckdb",
    "running",
    "training",
    "cli",
    "fitness"
  ],
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "fit": "dist/cli.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run typecheck && bun run build",
    "publish-check": "bun run scripts/prepublish-check.ts"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.4-r.1",
    "@opentui/core": "^0.1.81",
    "@opentui/react": "^0.1.81",
    "fit-file-parser": "^2.3.3",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "directories": {
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/davideast/fitui/issues"
  },
  "homepage": "https://github.com/davideast/fitui#readme"
}
