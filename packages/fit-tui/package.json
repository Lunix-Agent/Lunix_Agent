{
  "name": "fit-tui",
  "version": "0.1.0",
  "description": "FIT file database and query library for Bun",
  "type": "module",
  "private": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "bin": {
    "fitui": "./src/cli.ts"
  },
  "files": ["src"],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "bun run typecheck"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.4.4-r.1",
    "@opentui/core": "^0.1.81",
    "@opentui/react": "^0.1.81",
    "fit-file-parser": "^2.3.3",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
